import matplotlib.pyplot as plt
import numpy as np

# 数据
months = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月']

# 运动补剂
ydbj = [70, 75, 90, 95, 100, 115, 120, 135, 95, 80, 75, 90]

# 运动饮料 - 两条记录合并
ydyl_1 = [80, 85, 100, 105, 110, 125, 130, 145, 105, 90, 85, 100]
ydyl_2 = [8, 10, 15, 12, 4, 12, 8, 10, 18, 12, 20, 25]
ydyl = [ydyl_1[i] + ydyl_2[i] for i in range(12)]

# 创建图表
fig, ax = plt.subplots(figsize=(14, 7))

x = np.arange(len(months))
width = 0.35

bars1 = ax.bar(x - width/2, ydbj, width, label='运动补剂', color='#FF6B6B', alpha=0.85, edgecolor='white', linewidth=0.5)
bars2 = ax.bar(x + width/2, ydyl, width, label='运动饮料', color='#4ECDC4', alpha=0.85, edgecolor='white', linewidth=0.5)

# 在柱子上标注数值
for bar in bars1:
    height = bar.get_height()
    ax.annotate(f'{int(height)}',
                xy=(bar.get_x() + bar.get_width() / 2, height),
                xytext=(0, 3),
                textcoords="offset points",
                ha='center', va='bottom', fontsize=9, fontweight='bold', color='#FF6B6B')

for bar in bars2:
    height = bar.get_height()
    ax.annotate(f'{int(height)}',
                xy=(bar.get_x() + bar.get_width() / 2, height),
                xytext=(0, 3),
                textcoords="offset points",
                ha='center', va='bottom', fontsize=9, fontweight='bold', color='#4ECDC4')

# 添加折线趋势
ax.plot(x, ydbj, 'o-', color='#C0392B', linewidth=2.5, markersize=8, markerfacecolor='white', markeredgewidth=2, label='运动补剂趋势', zorder=5)
ax.plot(x, ydyl, 's-', color='#1ABC9C', linewidth=2.5, markersize=8, markerfacecolor='white', markeredgewidth=2, label='运动饮料趋势', zorder=5)

ax.set_xlabel('月份', fontsize=14, fontweight='bold')
ax.set_ylabel('销量', fontsize=14, fontweight='bold')
ax.set_title('运动饮料 vs 运动补剂 - 月度销量趋势对比', fontsize=18, fontweight='bold', pad=20)
ax.set_xticks(x)
ax.set_xticklabels(months, fontsize=12)
ax.legend(loc='upper left', fontsize=12, framealpha=0.9, edgecolor='gray')
ax.grid(axis='y', alpha=0.3, linestyle='--')
ax.set_ylim(0, max(max(ydbj), max(ydyl)) * 1.2)

# 添加背景色分区 - 上半年/下半年
ax.axvspan(-0.5, 5.5, alpha=0.05, color='#FFEAA7', label='上半年')
ax.axvspan(5.5, 11.5, alpha=0.05, color='#DFE6E9', label='下半年')

# 添加关键标注
ax.annotate('销量高峰\n(8月)', xy=(7, max(ydbj)), xytext=(7, max(ydbj)+25),
            arrowprops=dict(arrowstyle='->', color='#C0392B', lw=2),
            fontsize=11, color='#C0392B', fontweight='bold', ha='center')

ax.annotate('销量高峰\n(8月)', xy=(7, max(ydyl)), xytext=(7, max(ydyl)+25),
            arrowprops=dict(arrowstyle='->', color='#1ABC9C', lw=2),
            fontsize=11, color='#1ABC9C', fontweight='bold', ha='center')

plt.tight_layout()
print("图表已生成")

