import matplotlib
matplotlib.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']
matplotlib.rcParams['axes.unicode_minus'] = False

# 数据
months = list(range(1, 13))
months_label = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月']

# 银耳销量
yin_er = [3, 4, 6, 5, 1, 5, 3, 4, 8, 5, 10, 12]
# 木耳销量
mu_er = [1, 2, 3, 2, 1, 2, 1, 2, 4, 2, 5, 8]
# 红枣销量
hong_zao = [15, 20, 35, 40, 45, 60, 65, 80, 40, 25, 20, 35]

# 创建图表
fig, ax = plt.subplots(figsize=(14, 7))

# 绘制折线图
ax.plot(months, yin_er, 'o-', color='#FF6B6B', linewidth=2.5, markersize=8, label='银耳', markerfacecolor='white', markeredgewidth=2)
ax.plot(months, mu_er, 's-', color='#4ECDC4', linewidth=2.5, markersize=8, label='木耳', markerfacecolor='white', markeredgewidth=2)
ax.plot(months, hong_zao, '^-', color='#FFD93D', linewidth=2.5, markersize=8, label='红枣', markerfacecolor='white', markeredgewidth=2)

# 填充区域
ax.fill_between(months, yin_er, alpha=0.08, color='#FF6B6B')
ax.fill_between(months, mu_er, alpha=0.08, color='#4ECDC4')
ax.fill_between(months, hong_zao, alpha=0.08, color='#FFD93D')

# 标注数据点
for i, (y, m, h) in enumerate(zip(yin_er, mu_er, hong_zao)):
    ax.annotate(str(y), (months[i], y), textcoords="offset points", xytext=(0, 12), 
                ha='center', fontsize=9, color='#FF6B6B', fontweight='bold')
    ax.annotate(str(m), (months[i], m), textcoords="offset points", xytext=(0, -18), 
                ha='center', fontsize=9, color='#4ECDC4', fontweight='bold')
    if i % 2 == 0:
        ax.annotate(str(h), (months[i], h), textcoords="offset points", xytext=(0, 12), 
                    ha='center', fontsize=9, color='#FFD93D', fontweight='bold')

# 设置标题和标签
ax.set_title('银耳 vs 木耳 vs 红枣 全年销量趋势对比', fontsize=18, fontweight='bold', pad=20)
ax.set_xlabel('月份', fontsize=13, labelpad=10)
ax.set_ylabel('销量（件）', fontsize=13, labelpad=10)
ax.set_xticks(months)
ax.set_xticklabels(months_label, fontsize=11)
ax.legend(fontsize=13, loc='upper left', framealpha=0.9, edgecolor='gray')

# 网格
ax.grid(True, linestyle='--', alpha=0.3)
ax.set_xlim(0.5, 12.5)

plt.tight_layout()
plt.savefig('/tmp/sales_comparison.png', dpi=150, bbox_inches='tight')
print('/tmp/sales_comparison.png')

