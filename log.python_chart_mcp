# 月份标签
months = ['1月', '2月', '3月', '4月', '5月', '6月', 
          '7月', '8月', '9月', '10月', '11月', '12月']

# 创建图形，设置子图
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))

# 第一个子图：柱状图
bars = ax1.bar(months, monthly_sales, color='lightcoral', edgecolor='darkred', alpha=0.8)

# 添加数据标签
for bar, sales in zip(bars, monthly_sales):
    height = bar.get_height()
    ax1.text(bar.get_x() + bar.get_width()/2., height + 0.3,
             f'{sales}', ha='center', va='bottom', fontsize=10, fontweight='bold')

# 设置第一个子图的标题和标签
ax1.set_title(f'{product_name} - 月销量柱状图', fontsize=16, fontweight='bold', pad=20)
ax1.set_xlabel('月份', fontsize=12)
ax1.set_ylabel('销量（件）', fontsize=12)
ax1.set_ylim(0, max(monthly_sales) * 1.25)
ax1.grid(axis='y', alpha=0.3, linestyle='--')
ax1.set_xticklabels(months, rotation=45)

# 第二个子图：折线图+趋势线
x = np.arange(len(months))
ax2.plot(months, monthly_sales, 'o-', linewidth=3, markersize=8, 
         color='royalblue', markerfacecolor='gold', markeredgecolor='navy', 
         label='月销量')

# 添加趋势线
z = np.polyfit(x, monthly_sales, 1)
p = np.poly1d(z)
trend_line = p(x)
ax2.plot(months, trend_line, 'r--', linewidth=2, label=f'趋势线 (斜率: {z[0]:.2f})')

# 添加数据点标签
for i, (month, sales) in enumerate(zip(months, monthly_sales)):
    ax2.text(i, sales + 0.5, f'{sales}', ha='center', va='bottom', fontsize=9)

# 设置第二个子图的标题和标签
ax2.set_title(f'{product_name} - 销量趋势分析', fontsize=16, fontweight='bold', pad=20)
ax2.set_xlabel('月份', fontsize=12)
ax2.set_ylabel('销量（件）', fontsize=12)
ax2.set_ylim(0, max(monthly_sales) * 1.25)
ax2.grid(True, alpha=0.3, linestyle='--')
ax2.legend(loc='upper left')
ax2.set_xticklabels(months, rotation=45)

# 调整布局
plt.tight_layout()

# 显示图表
plt.show()

# 详细的数据分析
print("=" * 60)
print(f"商品名称: {product_name}")
print("=" * 60)

# 基本统计
total_sales = sum(monthly_sales)
avg_sales = total_sales / len(monthly_sales)
max_sales = max(monthly_sales)
min_sales = min(monthly_sales)
max_month = months[monthly_sales.index(max_sales)]
min_month = months[monthly_sales.index(min_sales)]

print(f"📊 年度销量统计:")
print(f"   全年总销量: {total_sales} 件")
print(f"   月平均销量: {avg_sales:.2f} 件")
print(f"   最高月销量: {max_sales} 件 (在{max_month})")
print(f"   最低月销量: {min_sales} 件 (在{min_month})")
print(f"   销量波动范围: {max_sales - min_sales} 件")

# 季度分析
quarters = [
    ("第一季度(1-3月)", sum(monthly_sales[0:3])),
    ("第二季度(4-6月)", sum(monthly_sales[3:6])),
    ("第三季度(7-9月)", sum(monthly_sales[6:9])),
    ("第四季度(10-12月)", sum(monthly_sales[9:12]))
]

print(f"\n📈 季度销量分析:")
for quarter_name, quarter_sales in quarters:
    quarter_avg = quarter_sales / 3
    print(f"   {quarter_name}: {quarter_sales} 件 (月均: {quarter_avg:.2f} 件)")

# 增长分析
growth_rates = []
for i in range(1, len(monthly_sales)):
    if monthly_sales[i-1] > 0:
        growth_rate = ((monthly_sales[i] - monthly_sales[i-1]) / monthly_sales[i-1]) * 100
        growth_rates.append(growth_rate)

if growth_rates:
    avg_growth = sum(growth_rates) / len(growth_rates)
    print(f"\n📈 月环比增长分析:")
    print(f"   平均月增长率: {avg_growth:.2f}%")
    
    # 找出增长最快的月份
    max_growth_idx = growth_rates.index(max(growth_rates)) + 1
    print(f"   增长最快月份: {months[max_growth_idx]} (增长率: {max(growth_rates):.2f}%)")

# 趋势分析
print(f"\n📈 销量趋势分析:")
print(f"   趋势线斜率: {z[0]:.2f}")
if z[0] > 0:
    print(f"   📈 整体呈上升趋势")
elif z[0] < 0:
    print(f"   📉 整体呈下降趋势")
else:
    print(f"   ➡️ 整体趋势平稳")

# 季节性分析
print(f"\n📊 季节性特征:")
print(f"   下半年销量(7-12月): {sum(monthly_sales[6:])} 件")
print(f"   上半年销量(1-6月): {sum(monthly_sales[:6])} 件")
print(f"   下半年/上半年比例: {sum(monthly_sales[6:])/sum(monthly_sales[:6]):.2f}")

# 销售建议
print(f"\n💡 销售建议:")
print(f"   1. 重点关注 {max_month} 的销售策略，保持高销量")
print(f"   2. 在 {min_month} 考虑促销活动提升销量")
print(f"   3. 下半年销量明显高于上半年，可加大下半年营销投入")
print(f"   4. 第四季度销量最高，可提前备货")
