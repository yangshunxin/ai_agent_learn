sports_drink_sales = [80, 85, 100, 105, 110, 125, 130, 145, 105, 90, 85, 100]

# 运动补剂月度销量
sports_supplement_sales = [70, 75, 90, 95, 100, 115, 120, 135, 95, 80, 75, 90]

# 北京月平均气温（℃）- 典型北方城市数据
avg_temps = [-3, 0, 8, 16, 22, 27, 29, 28, 22, 14, 5, -1]

# 季节划分：春(3-5), 夏(6-8), 秋(9-11), 冬(12-2)
seasons = ['冬','冬','春','春','春','夏','夏','夏','秋','秋','秋','冬']

# ========== 1. 相关性计算 ==========
# 运动饮料 vs 气温
r_drink_temp, p_drink_temp = stats.pearsonr(sports_drink_sales, avg_temps)
# 运动补剂 vs 气温
r_supp_temp, p_supp_temp = stats.pearsonr(sports_supplement_sales, avg_temps)
# 运动饮料 vs 运动补剂
r_drink_supp, p_drink_supp = stats.pearsonr(sports_drink_sales, sports_supplement_sales)

# Spearman秩相关（更稳健）
sr_drink_temp, sp_drink_temp = stats.spearmanr(sports_drink_sales, avg_temps)
sr_supp_temp, sp_supp_temp = stats.spearmanr(sports_supplement_sales, avg_temps)

print("="*60)
print("📊 相关性分析结果")
print("="*60)

print(f"\n【Pearson相关系数】")
print(f"运动饮料 vs 气温: r = {r_drink_temp:.4f}, p = {p_drink_temp:.6f}")
print(f"运动补剂 vs 气温: r = {r_supp_temp:.4f}, p = {p_supp_temp:.6f}")
print(f"运动饮料 vs 运动补剂: r = {r_drink_supp:.4f}, p = {p_drink_supp:.6f}")

print(f"\n【Spearman秩相关系数】")
print(f"运动饮料 vs 气温: ρ = {sr_drink_temp:.4f}, p = {sp_drink_temp:.6f}")
print(f"运动补剂 vs 气温: ρ = {sr_supp_temp:.4f}, p = {sp_supp_temp:.6f}")

# 判断相关性强度
def interpret_corr(r, name):
    if abs(r) >= 0.8:
        strength = "极强"
    elif abs(r) >= 0.6:
        strength = "强"
    elif abs(r) >= 0.4:
        strength = "中等"
    elif abs(r) >= 0.2:
        strength = "弱"
    else:
        strength = "极弱或无"
    direction = "正相关" if r > 0 else "负相关"
    print(f"{name}: {strength}{direction} (r={r:.4f})")

